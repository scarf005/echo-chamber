{
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite",
    "typecheck": "bash -lc 'shopt -s globstar nullglob; deno check src/**/*.ts src/**/*.tsx'",
    "check": "deno fmt --check && deno task typecheck && deno lint && deno test --parallel --allow-env=NODE_ENV",
    "fix": "deno fmt && deno lint",
    "setup:hooks": "deno run --allow-read --allow-write=./.git/hooks ./scripts/install_git_hooks.ts",
    "build": {
      "command": "deno run -A --node-modules-dir npm:vite build",
      "dependencies": ["i18n:extract"]
    },
    "test": "deno test --parallel --allow-env=NODE_ENV",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "serve": "deno run --allow-net --allow-read jsr:@std/http@1/file-server dist/",
    "i18n:extract": "deno cache --node-modules-dir ./lingui.config.ts && deno run -A --node-modules-dir ./node_modules/@lingui/cli/dist/lingui-extract.js --config ./lingui.config.ts --clean --workers 1",
    "i18n:compile": "deno run -A --node-modules-dir ./node_modules/@lingui/cli/dist/lingui-compile.js --config ./lingui.config.ts --typescript --workers 1"
  },
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "fmt": {
    "semiColons": false
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.5",
    "@preact/preset-vite": "npm:@preact/preset-vite@^2.10.2",
    "@preact/signals": "npm:@preact/signals@^2.8.1",
    "@std/async": "jsr:@std/async@1.2.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/collections": "jsr:@std/collections@^1.1.6",
    "@std/random": "jsr:@std/random@^0.1.5",
    "howler": "npm:howler@^2.2.4",
    "preact": "npm:preact@^10.28.0",
    "vite": "npm:vite@^7.2.7",
    "@lingui/cli": "npm:@lingui/cli@6.0.0-next.0",
    "@lingui/babel-plugin-lingui-macro": "npm:@lingui/babel-plugin-lingui-macro@6.0.0-next.0",
    "@lingui/core": "npm:@lingui/core@6.0.0-next.0",
    "@lingui/core/macro": "npm:@lingui/core@6.0.0-next.0/macro",
    "@lingui/react": "npm:@lingui/react@6.0.0-next.0",
    "@lingui/vite-plugin": "npm:@lingui/vite-plugin@6.0.0-next.0",
    "rot-js": "npm:rot-js@^2.2.1"
  }
}
